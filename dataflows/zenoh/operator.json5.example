// Zenoh config for the OPERATOR daemon. Copy to `operator-<host>.json5` and set
// the robot's address: its Tailscale IP for a remote robot, or 127.0.0.1 when the
// robot and operator daemons run on the same box.
//
// Config-free operation (default multicast scouting) was found to break the
// operator->robot direction — the robot received no teleop targets — so the
// operator gets an explicit, scouting-free peer config too.
//
// Use:  ZENOH_CONFIG=dataflows/remote/zenoh/operator-<host>.json5 \
//         uv run dora daemon --machine-id operator --coordinator-addr <ROBOT_ADDR>
{
  mode: "peer",
  connect: { endpoints: ["tcp/<ROBOT_ADDR>:5456"] },  // <ROBOT_ADDR> = robot Tailscale IP, or 127.0.0.1 same-box
  scouting: { multicast: { enabled: false } },
}
