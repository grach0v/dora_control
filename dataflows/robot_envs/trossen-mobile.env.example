# Host facts for `trossen-mobile` (the Trossen AI Mobile kit PC — its two WXAI LEADER
# arms are used as hand-guided teleop sources; they face forward). Copy to
# trossen-mobile.env.
#
# Default Trossen AI kit leader IPs (docs.trossenrobotics.com, lerobot configuration):
# leader left = 192.168.1.3, leader right = 192.168.1.2 (followers are .5/.4).
# Verify with the arms powered: ping, or the Trossen configuration tool.
#
# One file per host; a cross-robot dataflow loads every involved host's env file — see
# ur5-corner.env.example for the composed build/start commands.
LEFT_LEADER_IP=192.168.1.3
RIGHT_LEADER_IP=192.168.1.2
