# Host facts for `trossen-mobile` (the Trossen AI Mobile kit PC). Copy to
# trossen-mobile.env. One file per host, holding ONLY that host's facts; a dataflow
# loads the env file of EVERY host it touches (dora expands ${VAR} when
# `dora build`/`dora start` parse the YAML, on the machine running those commands) —
# see ur5-corner.env.example for a composed cross-robot example.
#
# Default Trossen AI kit arm IPs (docs.trossenrobotics.com, lerobot configuration):
# leaders left/right = 192.168.1.3/.2, followers left/right = 192.168.1.5/.4.
# Verify with the arms powered: ping, or the Trossen configuration tool.

# LEADER arms — hand-guided teleop sources (used by ur5e_dual_from_trossen_mobile.yml,
# where they drive the UR cell):
LEFT_LEADER_IP=192.168.1.3
RIGHT_LEADER_IP=192.168.1.2

# FOLLOWER arms — the mobile cell itself (used by trossen_mobile_remote_web.yml):
LEFT_ARM_IP=192.168.1.5
RIGHT_ARM_IP=192.168.1.4

# Cameras (used by modules/trossen_mobile_rig_module.yml):
# RealSense wrist serials (find with `rs-enumerate-devices -s`):
WRIST1=<realsense-serial>
WRIST2=<realsense-serial>
# The cart's USB camera — a v4l device path (or bare index), consumed by opencv-camera
# via CAMERA_INDEX. Paths can renumber across reboots: check `v4l2-ctl --list-devices`.
STATIC1=/dev/video16
