# Robot-specific values for a Trossen AI Stationary host. Copy to `<host>.env` and
# fill in. The remote dataflow YAMLs reference these as ${VAR}; dora expands them
# when it parses the YAML, so load this file into those commands:
#   uv run --env-file dataflows/remote/robots/<host>.env dora …
# The coordinator / zenoh rendezvous address is your robot host's Tailscale IP
# (passed via --coordinator-addr, not here).

# RealSense serial numbers (find with `rs-enumerate-devices -s`):
STATIC1=<realsense-serial>
STATIC2=<realsense-serial>
WRIST1=<realsense-serial>
WRIST2=<realsense-serial>

# Arm controller IPs (Trossen WXAI default LAN addresses):
LEFT_ARM_IP=192.168.1.5
RIGHT_ARM_IP=192.168.1.4
