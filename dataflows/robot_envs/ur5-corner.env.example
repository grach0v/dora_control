# Host facts for `ur5-corner` (the bimanual UR5e cell PC). Copy to ur5-corner.env.
#
# One file per host, holding ONLY that host's facts; a cross-robot dataflow loads the env
# file of EVERY host it touches (dora expands ${VAR} when `dora build`/`dora start` parse
# the YAML, on the machine running those commands):
#   uv run --env-file dataflows/remote/robots/ur5-corner.env \
#          --env-file dataflows/remote/robots/trossen-mobile.env \
#     dora build dataflows/remote/ur5e_dual/teleop_trossen_leader.yml --coordinator-addr <addr>
#
# Cell topology (each arm on its own dedicated NIC / subnet of this PC):
#   LEFT  = 192.168.59.10  (S/N ...75, has the teach pendant)   -> arm_left
#   RIGHT = 192.168.60.10  (S/N ...80)                          -> arm_right
LEFT_UR_IP=192.168.59.10
RIGHT_UR_IP=192.168.60.10
